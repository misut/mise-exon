#!/bin/sh
set -e

REPO="misut/exon"
VERSION="$ASDF_INSTALL_VERSION"

OS=$(uname -s)
ARCH=$(uname -m)

case "$OS-$ARCH" in
    Darwin-arm64)  PLATFORM="aarch64-apple-darwin" ;;
    Linux-aarch64) PLATFORM="aarch64-linux-gnu" ;;
    Linux-x86_64)  PLATFORM="x86_64-linux-gnu" ;;
    *)
        echo "error: unsupported platform $OS-$ARCH"
        echo "supported: macOS arm64, Linux x86_64, Linux aarch64"
        exit 1
        ;;
esac

URL="https://github.com/$REPO/releases/download/v$VERSION/exon-v$VERSION-$PLATFORM.tar.gz"

echo "downloading exon v$VERSION ($PLATFORM)..."
curl -fsSL "$URL" -o "$ASDF_DOWNLOAD_PATH/exon.tar.gz"
tar -xzf "$ASDF_DOWNLOAD_PATH/exon.tar.gz" -C "$ASDF_DOWNLOAD_PATH"
rm "$ASDF_DOWNLOAD_PATH/exon.tar.gz"
